generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum DocumentRequestStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  GENERATING
  PENDING_REVIEW
  COMPLETED
  FAILED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILURE
  REVERSED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

model Article {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  excerpt     String
  category    String
  author      String        @default("Кабаль Анастасія")
  coverImage  String?
  readTime    String        @default("5 хв")
  blocks      Json // ContentBlock[] — див. src/lib/content-blocks.ts
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PracticeArea {
  id               String        @id @default(cuid())
  slug             String        @unique
  title            String
  shortDescription String
  icon             String // emoji
  description      String // абзаци, розділені \n\n
  services         String[]
  advantages       String[]
  process          Json // { step, title, description }[]
  status           ContentStatus @default(PUBLISHED)
  sortOrder        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Review {
  id        String        @id @default(cuid())
  kind      String        @default("review") // "review" | "case"
  name      String
  text      String
  result    String? // для кейсів
  rating    Int           @default(5)
  service   String
  photos    String[] // URL скріншотів у R2
  featured  Boolean       @default(false) // показ на головній
  status    ContentStatus @default(PUBLISHED)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Sample {
  id          String        @id @default(cuid())
  title       String
  description String
  fileUrl     String
  sizeLabel   String
  iconKey     String        @default("document")
  status      ContentStatus @default(PUBLISHED)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Certificate {
  id        String        @id @default(cuid())
  title     String
  imageUrl  String
  status    ContentStatus @default(PUBLISHED)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documentRequests DocumentRequest[]
  payments         Payment[]
}

model DocumentTemplate {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String
  category    String
  price       Float
  promptHint  String?
  fields      Json
  isActive    Boolean @default(true)
  sortOrder   Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documentRequests DocumentRequest[]
}

model DocumentRequest {
  id         String                @id @default(cuid())
  templateId String
  userId     String?
  status     DocumentRequestStatus @default(DRAFT)

  partyData         Json
  circumstancesData Json
  requirementsData  Json

  generatedText String?
  legalSources  String?
  pdfUrl        String?
  lawyerNotes   String?

  contactEmail String
  contactPhone String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  template DocumentTemplate @relation(fields: [templateId], references: [id])
  user     User?            @relation(fields: [userId], references: [id])
  payment  Payment?
}

model Payment {
  id                String        @id @default(cuid())
  documentRequestId String        @unique
  userId            String?
  amount            Float
  status            PaymentStatus @default(PENDING)
  liqpayOrderId     String        @unique
  liqpayPaymentId   String?
  liqpayStatus      String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  documentRequest DocumentRequest @relation(fields: [documentRequestId], references: [id])
  user            User?           @relation(fields: [userId], references: [id])
}
